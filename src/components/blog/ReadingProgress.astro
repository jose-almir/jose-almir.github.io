<div
  id="reading-progress-container"
  class="fixed top-0 left-0 w-full h-0.75 bg-transparent z-50 pointer-events-none"
>
  <div
    id="reading-progress-bar"
    class="h-full bg-primary dark:bg-accent w-0 transition-all duration-150 ease-out"
  >
  </div>
</div>

<script>
  function updateProgress() {
    const progress = document.getElementById("reading-progress-bar");
    if (!progress) return;

    const scrollPosition = window.scrollY;
    const windowHeight = window.innerHeight;
    const documentHeight = document.documentElement.scrollHeight;

    const scrollPercentage =
      (scrollPosition / (documentHeight - windowHeight)) * 100;

    const cappedPercentage = Math.min(100, Math.max(0, scrollPercentage));
    progress.style.width = `${cappedPercentage}%`;
  }

  window.addEventListener("scroll", updateProgress, { passive: true });
  updateProgress();
</script>
