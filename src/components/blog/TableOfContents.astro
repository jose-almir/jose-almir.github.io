---
import { useTranslations } from "../../i18n";
import type { MarkdownHeading } from "astro";

interface Props {
  headings: MarkdownHeading[];
  lang: string;
}

const { headings, lang } = Astro.props;
const t = useTranslations(lang as "en" | "pt");

const toc = headings.filter(
  (heading) => heading.depth === 2 || heading.depth === 3,
);
---

{
  toc.length > 0 && (
    <div class="not-prose mb-10">
      <nav
        aria-label="Table of Contents"
        class="bg-zinc-50 dark:bg-zinc-800/30 border border-zinc-200 dark:border-zinc-800 rounded-xl p-5 sm:p-6 shadow-sm max-w-2xl mx-auto"
      >
        <h2 class="text-xs font-bold mb-3 uppercase tracking-wider text-zinc-900 dark:text-zinc-100">
          {t("blog.toc")}
        </h2>
        <ul class="list-none m-0 p-0 border-l-2 border-zinc-200 dark:border-zinc-700 flex flex-col gap-2">
          {toc.map((heading) => (
            <li class={`m-0 p-0 ${heading.depth === 3 ? "pl-5" : "pl-3"}`}>
              <a
                href={`#${heading.slug}`}
                class="text-zinc-600 dark:text-zinc-400 hover:text-primary dark:hover:text-accent hover:underline transition-colors duration-200 block text-sm"
              >
                {heading.text}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </div>
  )
}

<style>
  html {
    scroll-behavior: smooth;
  }
</style>
