---
interface Props {
  title?: string;
}

const { title = "Terminal" } = Astro.props;
---

<div
  class="my-6 rounded-lg overflow-hidden shadow-xl border border-zinc-200 dark:border-zinc-800 bg-[#ffffff] dark:bg-[#2e3440]"
>
  <div
    class="flex items-center px-4 py-3 bg-zinc-100 dark:bg-[#232831] border-b border-zinc-200 dark:border-zinc-800"
  >
    <div class="flex gap-2">
      <div class="w-3 h-3 rounded-full bg-red-500"></div>
      <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
      <div class="w-3 h-3 rounded-full bg-green-500"></div>
    </div>
    <div class="flex-1 text-center">
      <span
        class="text-xs font-medium text-zinc-500 dark:text-zinc-400 font-mono"
        >{title}</span
      >
    </div>
    <div class="w-11"></div>
  </div>
  <div
    class="p-4 has-[pre]:p-0 [&_pre]:m-0! [&_pre]:rounded-none! [&_pre]:border-0! [&_pre]:shadow-none! [&_pre]:bg-transparent! text-sm font-mono text-zinc-800 dark:text-zinc-200"
  >
    <slot />
  </div>
</div>
