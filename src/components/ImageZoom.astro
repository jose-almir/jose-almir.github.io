---
// ImageZoom.astro
---

<script>
  import mediumZoom from "medium-zoom";

  document.addEventListener("astro:page-load", () => {
    mediumZoom(".blog-content img, .project-content img", {
      margin: 24,
      background: "rgba(0, 0, 0, 0.9)",
    });
  });
</script>

<style is:global>
  .medium-zoom-overlay {
    z-index: 50;
  }
  .medium-zoom-image--opened {
    z-index: 51;
  }
</style>
